# ─────────────────────────────────────────────────────────────
# CitationTrace — Backend Environment Variables
# Copy this file to .env and fill in your values.
# The backend runs without any keys; LangSmith is optional.
# ─────────────────────────────────────────────────────────────

# ── LangSmith (optional) ──────────────────────────────────────
# Get your API key at https://smith.langchain.com → Settings → API Keys
# Starts with: lsv2_...
LANGSMITH_API_KEY=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

# Project name shown in LangSmith dashboard (can be anything)
LANGSMITH_PROJECT=citationtrace

# Required for LangChain tracing to activate
LANGCHAIN_TRACING_V2=true

# LangSmith ingestion endpoint (do not change)
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
